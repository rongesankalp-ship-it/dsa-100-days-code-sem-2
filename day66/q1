Problem: Detect cycle in directed graph using DFS and recursion stack.

Output:
- YES if cycle exists



#include <stdio.h>
#include <stdbool.h>

#define MAX 100

bool dfs(int node, int V, int adj[MAX][MAX], bool visited[], bool recStack[]) {
    visited[node] = true;
    recStack[node] = true;

    for (int i = 0; i < V; i++) {
        if (adj[node][i]) {
            // If not visited → DFS
            if (!visited[i] && dfs(i, V, adj, visited, recStack))
                return true;

            // If already in recursion stack → cycle
            else if (recStack[i])
                return true;
        }
    }

    recStack[node] = false; // remove from recursion stack
    return false;
}

bool isCycle(int V, int adj[MAX][MAX]) {
    bool visited[MAX] = {false};
    bool recStack[MAX] = {false};

    for (int i = 0; i < V; i++) {
        if (!visited[i]) {
            if (dfs(i, V, adj, visited, recStack))
                return true;
        }
    }
    return false;
}

int main() {
    int V = 4;

    // Example adjacency matrix
    int adj[MAX][MAX] = {0};

    // Directed edges
    adj[0][1] = 1;
    adj[1][2] = 1;
    adj[2][3] = 1;
    adj[3][1] = 1; // Creates a cycle

    if (isCycle(V, adj))
        printf("YES\n");
    else
        printf("NO\n");

    return 0;
}
