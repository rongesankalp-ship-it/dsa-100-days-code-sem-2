Problem: Sort array of non-negative integers using counting sort.
Find max, build freq array, compute prefix sums, build output.


#include <stdio.h>
#include <stdlib.h>

// Counting Sort Function
void countingSort(int arr[], int n)
{
    int i;

    // Step 1: Find maximum element
    int max = arr[0];
    for(i = 1; i < n; i++)
    {
        if(arr[i] > max)
            max = arr[i];
    }

    // Step 2: Create frequency array
    int count[max + 1];

    // Initialize count array with 0
    for(i = 0; i <= max; i++)
    {
        count[i] = 0;
    }

    // Store frequencies
    for(i = 0; i < n; i++)
    {
        count[arr[i]]++;
    }

    // Step 3: Compute prefix sums
    for(i = 1; i <= max; i++)
    {
        count[i] += count[i - 1];
    }

    // Step 4: Build output array
    int output[n];

    // Traverse from end for stable sorting
    for(i = n - 1; i >= 0; i--)
    {
        output[count[arr[i]] - 1] = arr[i];
        count[arr[i]]--;
    }

    // Copy output back to original array
    for(i = 0; i < n; i++)
    {
        arr[i] = output[i];
    }
}

// Print Array Function
void printArray(int arr[], int n)
{
    for(int i = 0; i < n; i++)
    {
        printf("%d ", arr[i]);
    }
    printf("\n");
}

// Main Function
int main()
{
    int arr[] = {4, 2, 2, 8, 3, 3, 1};
    int n = sizeof(arr) / sizeof(arr[0]);

    printf("Original Array:\n");
    printArray(arr, n);

    countingSort(arr, n);

    printf("Sorted Array:\n");
    printArray(arr, n);

    return 0;
}
