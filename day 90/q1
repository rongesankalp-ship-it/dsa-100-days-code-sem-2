Problem Statement
Given n boards of different lengths and k painters, each painter paints contiguous boards. Painting a unit length of board takes one unit of time.

Determine the minimum time required to paint all boards.

Input Format
n k
n space-separated integers representing board lengths

Output Format
Print the minimum time required to paint all boards.

Sample Input
4 2
10 20 30 40

Sample Output
60

Explanation
One painter paints boards of length 10, 20, and 30 (total 60), while the other paints board of length 40



#include <stdio.h>

// Function to check if boards can be painted
// within maxTime using at most k painters
int canPaint(int boards[], int n, int k, int maxTime) {
    int painters = 1;
    int currentTime = 0;

    for (int i = 0; i < n; i++) {

        // Add board to current painter
        if (currentTime + boards[i] <= maxTime) {
            currentTime += boards[i];
        }
        else {
            // Assign new painter
            painters++;
            currentTime = boards[i];

            // More than k painters needed
            if (painters > k)
                return 0;
        }
    }

    return 1;
}

// Function to find minimum time
int minTime(int boards[], int n, int k) {
    int low = boards[0];
    int high = 0;

    // Find max board length and total sum
    for (int i = 0; i < n; i++) {
        if (boards[i] > low)
            low = boards[i];

        high += boards[i];
    }

    int result = high;

    // Binary Search
    while (low <= high) {
        int mid = (low + high) / 2;

        if (canPaint(boards, n, k, mid)) {
            result = mid;
            high = mid - 1; // Try smaller answer
        }
        else {
            low = mid + 1; // Increase limit
        }
    }

    return result;
}

int main() {
    int n, k;

    // Input
    scanf("%d %d", &n, &k);

    int boards[n];

    for (int i = 0; i < n; i++) {
        scanf("%d", &boards[i]);
    }

    // Output
    printf("%d\n", minTime(boards, n, k));

    return 0;
}
